package httpapi

import (
	"net/http"
	"strings"

	"github.com/gin-gonic/gin"

	"ipinfo-http-server/internal/ipinfo"
	"ipinfo-http-server/internal/ratelimit"
	"ipinfo-http-server/internal/validator"
)

type Server struct {
	ipClient *ipinfo.Client
	limiter  *ratelimit.RateLimiter
}

type IPRequest struct {
	IP string `json:"ip" binding:"required"`
}

func NewServer(ipClient *ipinfo.Client, limiter *ratelimit.RateLimiter) *Server {
	return &Server{
		ipClient: ipClient,
		limiter:  limiter,
	}
}

func (s *Server) RegisterRoutes(r *gin.Engine) {
	r.GET("/", s.help)
	r.GET("/health", s.health)

	api := r.Group("/api")
	api.GET("/ip/:ip", s.getIPInfoByParam)
	api.POST("/ip", s.getIPInfoByBody)
}

func (s *Server) help(c *gin.Context) {
	c.JSON(http.StatusOK, gin.H{
		"name":        "IPInfo HTTP server",
		"description": "HTTP version of the first semester IP geolocation lab",
		"endpoints": []string{
			"GET /health",
			"GET /api/ip/:ip",
			"POST /api/ip with JSON body {\"ip\":\"8.8.8.8\"}",
		},
	})
}

func (s *Server) health(c *gin.Context) {
	c.JSON(http.StatusOK, gin.H{
		"status": "ok",
	})
}

func (s *Server) getIPInfoByParam(c *gin.Context) {
	s.handleIP(c, c.Param("ip"))
}

func (s *Server) getIPInfoByBody(c *gin.Context) {
	var req IPRequest
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{
			"error":   "ip field is required",
			"example": gin.H{"ip": "8.8.8.8"},
		})
		return
	}

	s.handleIP(c, req.IP)
}

func (s *Server) handleIP(c *gin.Context, value string) {
	ip := strings.TrimSpace(value)
	if !validator.IsValidIP(ip) {
		c.JSON(http.StatusBadRequest, gin.H{
			"error": "invalid IP address",
			"examples": []string{
				"8.8.8.8",
				"2001:4860:4860::8888",
			},
		})
		return
	}

	if !s.limiter.Allow(c.ClientIP()) {
		c.JSON(http.StatusTooManyRequests, gin.H{
			"error": "too many requests, please wait before the next request",
		})
		return
	}

	info, err := s.ipClient.GetInfo(ip)
	if err != nil {
		c.JSON(http.StatusBadGateway, gin.H{
			"error": err.Error(),
		})
		return
	}

	c.JSON(http.StatusOK, info)
}
